# SkillOS Environment Configuration Template
# Copy this file to .env and fill in your local configuration
# NOTE: .env is in .gitignore and should NEVER be committed

### GitHub Configuration ###
# GitHub API token for automated PR operations (if using Codex CLI)
# GITHUB_TOKEN=your_github_token_here

# GitHub repository (owner/repo format)
# GITHUB_REPO=Joshanihub/SkillOS

### Model Configuration ###
# Primary model for skill generation and testing
# Options: claude-opus, claude-fable-5, gpt-5.5, gemini-3.1-pro, etc.
# PRIMARY_MODEL=claude-fable-5

# Model for validation testing (can be different from primary)
# VALIDATION_MODEL=claude-haiku-4.5

# OpenAI API key (if using GPT models)
# OPENAI_API_KEY=your_openai_api_key

# Anthropic API key (if using Claude models)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Google API key (if using Gemini models)
# GOOGLE_API_KEY=your_google_api_key

### SkillOS Configuration ###
# Registry path (relative to project root)
REGISTRY_PATH=./registry

# Test output directory (will be gitignored)
TEST_OUTPUT_DIR=./SkillOsTests

# Validation harness path
VALIDATION_HARNESS_PATH=./test-harness.md

# SDS schema version
SDS_VERSION=1.0

### Logging Configuration ###
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log output directory (will be gitignored)
LOG_DIR=./logs

### Development Configuration ###
# Enable verbose output
VERBOSE=false

# Enable debug mode
DEBUG=false

# Dry-run mode (don't commit or push changes)
DRY_RUN=false

### Project Metadata ###
# Project version (updated during releases)
PROJECT_VERSION=1.0.0

# Project maintainer email
MAINTAINER_EMAIL=your_email@example.com

# Enable telemetry (anonymous usage statistics)
TELEMETRY_ENABLED=true

### API Endpoints ###
# GitHub API endpoint (usually github.com, can be self-hosted)
GITHUB_API_URL=https://api.github.com

# Optional: Self-hosted Gitea or GitHub Enterprise endpoint
# GITHUB_API_URL=https://your-github-enterprise.com/api/v3
